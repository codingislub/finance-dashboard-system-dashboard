{
  "name": "finance-data-processing-backend",
  "version": "1.0.0",
  "description": "Finance dashboard backend with RBAC and summary analytics",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "cross-env DATABASE_URL=file:./dev.db prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "tsx --test test/all.test.ts",
    "prisma:generate": "cross-env DATABASE_URL=file:./dev.db prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "tsx prisma/seed.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "backend",
    "finance",
    "rbac",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "cross-env": "^10.1.0",
    "prisma": "^7.6.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
